# Configuração de Ambiente

# Modo de desenvolvimento
NODE_ENV=development

# Configuração de Origens Permitidas (para comunicação com iframe)
# Separadas por vírgula
VITE_ALLOWED_PARENT_ORIGINS=http://localhost:3000,http://localhost:5173

# URLs de CDN para recursos estáticos
# Se não especificado, usará URLs locais
VITE_CDN_BASE_URL=http://localhost:5173

# Configurações opcionais da Hostinger (deixe em branco se não usar)
TEMPLATE_BANNER_SCRIPT_URL=
TEMPLATE_REDIRECT_URL=

# Habilitar handlers de erro da Hostinger (para comunicação com iframe pai)
VITE_ENABLE_HORIZONS_HANDLERS=false

# Modo de produção - desabilitar inline editing
VITE_DISABLE_INLINE_EDITING=false
